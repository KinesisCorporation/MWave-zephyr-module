        Clique_12: Clique_12{
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            display-name = "Custom Macro 12";
            bindings = <&pos_trig 413 &pos_trig 414 &pos_trig 415 &pos_trig 416 &pos_trig 417 &pos_trig 418 &pos_trig 419 &pos_trig 420 &pos_trig 421 &pos_trig 422 &pos_trig 423 &pos_trig 424 &pos_trig 425 &pos_trig 426 &pos_trig 427 &pos_trig 428 &pos_trig 429 &pos_trig 430 &pos_trig 431 &pos_trig 432 &pos_trig 433 &pos_trig 434 &pos_trig 435 &pos_trig 436 &pos_trig 437 &pos_trig 438 &pos_trig 439 &pos_trig 440 &pos_trig 441 &pos_trig 442 &pos_trig 443 &pos_trig 444 &pos_trig 445 &pos_trig 446 &pos_trig 447 &pos_trig 448 >;
        };
  };

  endpoint_sideband_behaviors {
      auto-enable;
      compatible = "zmk,kscan-sideband-behaviors";
      kscan = <&kscan_sp3t_toggle>;

      first_toggle_sideband: first_toggle_sideband {
          column = <0>;
          bindings = <&usb_conn>;
      };

      second_toggle_sideband: second_toggle_sideband {
          column = <1>;
          bindings = <&ble_zero>;
      };

      third_toggle_sideband: third_toggle_sideband {
          column = <2>;
          bindings = <&ble_one>;
      };
  };

  keymap {
    compatible = "zmk,keymap";
    default_layer {
      bindings = <
        &kp KP_NUMLOCK &kp KP_SLASH &kp KP_ASTERISK &bt BT_CLR
        &kp KP_N7      &kp KP_N8    &kp KP_N9       &kp KP_PLUS
        &kp KP_N4      &kp KP_N5    &kp KP_N6 
        &kp KP_N1      &kp KP_N2    &kp KP_N3       &kp KP_ENTER 
               &kp KP_N0            &kp KP_DOT  
        &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none &none 

            bindings = <&pos_trig 377 &pos_trig 378 &pos_trig 379 &pos_trig 380 &pos_trig 381 &pos_trig 382 &pos_trig 383 &pos_trig 384 &pos_trig 385 &pos_trig 386 &pos_trig 387 &pos_trig 388 &pos_trig 389 &pos_trig 390 &pos_trig 391 &pos_trig 392 &pos_trig 393 &pos_trig 394 &pos_trig 395 &pos_trig 396 &pos_trig 397 &pos_trig 398 &pos_trig 399 &pos_trig 400 &pos_trig 401 &pos_trig 402 &pos_trig 403 &pos_trig 404 &pos_trig 405 &pos_trig 406 &pos_trig 407 &pos_trig 408 &pos_trig 409 &pos_trig 410 &pos_trig 411 &pos_trig 412 >;

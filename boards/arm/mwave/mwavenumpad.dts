    };
 
     led_0: led_0 {
         compatible = "gpio-leds";
         red_led: led_0r {
             gpios = <&shifter2 5 GPIO_ACTIVE_LOW>;
         };
         green_led: led_0g {
             gpios = <&shifter2 6 GPIO_ACTIVE_LOW>;
         };
         blue_led: led_0b {
             gpios = <&shifter2 7 GPIO_ACTIVE_LOW>;
         };
     };
 
     led_1: led_1 {
         compatible = "gpio-leds";
         red_led1: led_1r {
             gpios = <&shifter2 2 GPIO_ACTIVE_LOW>;
         };
         green_led1: led_1g {
             gpios = <&shifter2 3 GPIO_ACTIVE_LOW>;
         };
         blue_led1: led_1b {
             gpios = <&shifter2 4 GPIO_ACTIVE_LOW>;
         };
     };
 
     led_strip_1: gpio_led_strip {
         compatible = "zmk,gpio-led-strip";
         chain-length = <2>;
         led-0 {
             led = <&led_0>;
         };
         led-1 {
             led = <&led_1>;
         };
     };
};

/delete-node/ &shifter;

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 31 GPIO_ACTIVE_LOW>;
	shifter2: 595@0 {
		compatible = "zmk,gpio-595";
		status = "okay";
		gpio-controller;
		spi-max-frequency = <200000>;
		reg = <0>;
		#gpio-cells = <2>;
		ngpios = <8>;
	};
};